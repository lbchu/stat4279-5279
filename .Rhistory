library(glmnet)
# ------------------------------------------------------------------
# Outcome regression adjustment
# ------------------------------------------------------------------
fit_m0_ridge <- function(X_ctrl, Y_ctrl) {
cv.glmnet(x = as.matrix(X_ctrl), y = Y_ctrl, alpha = 0)
}
predict_m0_ridge <- function(fit, X_new) {
as.numeric(predict(fit, newx = as.matrix(X_new), s = "lambda.min"))
}
estimate_att_postmatch_ra <- function(X_T, Y_T, X_C, Y_C, match_idx) {
X_M <- X_C[match_idx, , drop = FALSE]
Y_M <- Y_C[match_idx]
att_naive <- mean(Y_T - Y_M)
fit_m0 <- fit_m0_ridge(X_M, Y_M)
mu0_hat_T <- predict_m0_ridge(fit_m0, X_T)
att_ra <- mean(Y_T - mu0_hat_T)
list(att_naive = att_naive, att_ra = att_ra, model = fit_m0)
}
# ------------------------------------------------------------------
# Settings
# ------------------------------------------------------------------
B <- 10
nT <- 100
nT2 <- 100
nC <- 400
n <- nT + nC
d <- 200
k <- nT / 2
k_eval <- nT / 4
treat_index <- 1:nT
control_index <- (nT + 1):n
tt <- c(rep(1, nT), rep(0, nC))
# treatment distribution: independent N(0, I)
rho_nT <- 0
Sigma_nT <- diag(d)
mu_nT <- 0
sigma_nT <- 1
# alternative controls: same mean, stronger joint structure
rho_nC <- 0
Sigma_nC <- toeplitz(rho_nC^(0:(d - 1)))
mu_nC <- 2
sigma_nC <- 1
# nonlinear basis used for evaluation and outcome model
subset_idx <- 1:d
n_sq <- 10
n_int <- 10
# constant ATT; control potential outcomes depend on nonlinear terms
generate_beta_isotropic <- function(d) {
z <- rnorm(d)
beta <- z / sqrt(sum(z^2))
return(beta)
}
gamma <- rep(0, d)
beta_nl <- 1
gamma_nl <- 0
sigma_y <- 1
# ------------------------------------------------------------------
# Helpers
# ------------------------------------------------------------------
asd_fields <- c(
"asd_min_mean", "asd_max_mean", "asd_mean",
"asd_min_var", "asd_max_var", "asd_var",
"asd_cov", "asd_cor", "frob_cov", "dif", "SS", "ep",
"ps_std_diff", "ps_var_ratio", "ks_ps", "resid_var_ratio_mean",
"overlap_rate","overlap_rate_unique"
)
distance_fields <- c("within1_mean", "within2_mean", "btwn_mean")
gb_fields <- c("Z1Z2sum", "ZNN", "ZMST")
nl_fields <- c("asmd_mean_nl", "asmd_max_nl", "lvr_mean_nl", "lvr_max_nl", "mom2_frob", "mom2_max")
oracle_fields = c("mu0_treat_gap","mu0_good_gap","abs_mu0_treat_gap","abs_mu0_good_gap",
"var_Y_T","var_Y_C",
"Y0_treat_gap","tau_matched_gap")
make_metric_store <- function(method_names, B, field_names) {
out <- setNames(vector("list", length(method_names)), method_names)
for (m in method_names) {
out[[m]] <- matrix(NA_real_, nrow = B, ncol = length(field_names),
dimnames = list(NULL, field_names))
}
out
}
summarize_metric_store <- function(store) {
do.call(rbind, lapply(store, colMeans, na.rm = TRUE))
}
summarize_error_store <- function(err_store) {
out <- do.call(rbind, lapply(err_store, function(e) {
c(bias = mean(abs(e), na.rm = TRUE), mse = mean(e^2, na.rm = TRUE), variance = var(e,na.rm=TRUE))
}))
as.data.frame(out)
}
# ------------------------------------------------------------------
# Storage
# ------------------------------------------------------------------
asd_initial <- make_metric_store(initial_names, B, asd_fields)
distance_initial <- make_metric_store(initial_names, B, distance_fields)
graph_initial <- make_metric_store(initial_names, B, gb_fields)
nl_initial <- make_metric_store(initial_names, B, nl_fields)
oracle_initial <- make_metric_store(initial_names, B, oracle_fields)
bias_initial <- setNames(vector("list", length(initial_names)), initial_names)
bias_RA_initial <- setNames(vector("list", length(initial_names)), initial_names)
for (m in initial_names) {
bias_initial[[m]] <- rep(NA_real_, B)
bias_RA_initial[[m]] <- rep(NA_real_, B)
}
asd_truth <- Zsum_greedy_knn_asd <- matrix(NA_real_, B, length(asd_fields), dimnames = list(NULL, asd_fields))
distance_truth <- Zsum_greedy_knn_distance <- matrix(NA_real_, B, length(distance_fields), dimnames = list(NULL, distance_fields))
graph_truth <- Zsum_greedy_knn_graph <- matrix(NA_real_, B, length(gb_fields), dimnames = list(NULL, gb_fields))
nl_truth <- Zsum_greedy_knn_nl <- matrix(NA_real_, B, length(nl_fields), dimnames = list(NULL, nl_fields))
oracle_truth <- Zsum_greedy_knn_oracle <- matrix(NA_real_, B, length(oracle_fields), dimnames = list(NULL, oracle_fields))
bias_truth = Zsum_greedy_knn_bias <- rep(NA_real_, B)
debias_lin_truth = Zsum_greedy_knn_debias_lin <- rep(NA_real_, B)
debias_nl_truth = Zsum_greedy_knn_debias_nl <- rep(NA_real_, B)
# ------------------------------------------------------------------
# Main loop
# ------------------------------------------------------------------
for (b in seq_len(B)) {
beta <- generate_beta_isotropic(d)
sim <- simulate_data_corr_sparse_with_outcome(
nT = nT, nT2 = nT2, nC = nC, d = d,
mu_nT = mu_nT, mu_nC = mu_nC,
rho_nT = rho_nT, rho_nC = rho_nC,
Sigma_nT = Sigma_nT, Sigma_nC = Sigma_nC,
sigma_nT = sigma_nT, sigma_nC = sigma_nC,
tau0 = 1,
beta = beta,
gamma = gamma,
sigma_y = sigma_y,
subset_idx = subset_idx,
n_sq = n_sq,
n_int = n_int,
beta_nl = generate_beta_isotropic(n_sq+n_int),
gamma_nl = gamma_nl
)
is_overlap <- c(rep(FALSE, nT), sim$control_component == "overlap")
X <- sim$data
distM <- sim$distM
X_eval <- sim$data_eval
distM_eval <- sim$distM_eval
X_T_lin <- X[treat_index, , drop = FALSE]
X_C_lin <- X[control_index, , drop = FALSE]
X_T_eval <- X_eval[treat_index, , drop = FALSE]
X_C_eval <- X_eval[control_index, , drop = FALSE]
Y_T <- sim$Y_T
Y_C <- sim$Y_C
# graph for greedy refinement is built on the matching space, not evaluation space
A_knn <- compute_A_generic(distM, k = k, method = "knn")
# propensity scores estimated on the matching covariates only
X_ps <- scale(model.matrix(~ . - 1, data = as.data.frame(X)))
fit_nn <- nnet::nnet(
X_ps, tt,
size = 3,
decay = 0.1,
entropy = TRUE,
trace = FALSE,
maxit = 200,
MaxNWts = 10000
)
pscore_est <- as.numeric(predict(fit_nn, newdata = X_ps, type = "raw"))
track_list <- setNames(vector("list", length(initial_names)), initial_names)
for (m in initial_names) {
matched_controls <- initial_methods[[m]](
X = X,
distM = distM,
t = tt,
nT = nT,
nC = nC,
pscore_est = pscore_est,
treat_index = treat_index,
control_index = control_index
)
res <- compute_metric_one(
matched_controls = matched_controls,
X = X_eval,
distM = distM_eval,
treat_index = treat_index,
pscore_est = pscore_est,
k = k_eval,
A_method = "knn",
is_overlap = is_overlap
)
nl_res <- calc_nonlinear_eval(
X_raw = X,
X_eval = X_eval,
treat_index = treat_index,
control_index = matched_controls,
n_lin = ncol(X),
subset_idx = subset_idx
)
asd_initial[[m]][b, ] <- res$asd
distance_initial[[m]][b, ] <- res$distance
graph_initial[[m]][b, ] <- res$graph
nl_initial[[m]][b, ] <- nl_res
bias_initial[[m]][b] <- estimate_att_from_matches(Y_T, Y_C, match_idx = matched_controls - nT) - sim$true_ATT
# linear regression adjustment
bias_RA_initial[[m]][b] <- estimate_att_postmatch_ra(
X_T = X_T_lin,
Y_T = Y_T,
X_C = X_C_lin,
Y_C = Y_C,
match_idx = matched_controls - nT
)$att_ra - sim$true_ATT
oracle_res <- compute_oracle_diagnostics(
mu0_T = sim$mu0_T,
mu0_C = sim$mu0_C,
Y_T = sim$Y_T,
Y_C = sim$Y_C,
control_component = sim$control_component,
match_idx = matched_controls - nT,
tau_T = sim$tau_T,
tau_C = sim$tau_C,
Y0_C = sim$Y0_C,
Y1_C = sim$Y1_C,
Y0_T = sim$Y0_T,
true_ATC = sim$true_ATC
)
oracle_initial[[m]][b,] = oracle_res
track_list[[m]] <- c(treat_index, matched_controls)
}
otherC_list <- lapply(track_list, function(idx) control_index[control_index %nin% idx])
tmp_greedy_knn <- run_gb_matching(
X, distM, X_eval, distM_eval,
distMW = NULL,
A = A_knn,
treat_index,
track_list,
otherC_list,
k, k_eval, nT,
use_weighted = FALSE,
A_method = "knn",
pscore_est = pscore_est,
is_overlap = is_overlap
)
Zsum_greedy_knn_asd[b, ] <- unlist(tmp_greedy_knn$res_Zsum$asd)
Zsum_greedy_knn_distance[b, ] <- unlist(tmp_greedy_knn$res_Zsum$distance)
Zsum_greedy_knn_graph[b, ] <- unlist(tmp_greedy_knn$res_Zsum$graph)
Zsum_greedy_knn_nl[b, ] <- calc_nonlinear_eval(
X_raw = X,
X_eval = X_eval,
treat_index = treat_index,
control_index = tmp_greedy_knn$matched_Zsum,
n_lin = ncol(X),
subset_idx = subset_idx
)
Zsum_greedy_knn_bias[b] <- estimate_att_from_matches(
Y_T, Y_C,
match_idx = tmp_greedy_knn$matched_Zsum - nT
) - sim$true_ATT
# linear RA on original covariates
Zsum_greedy_knn_debias_lin[b] <- estimate_att_postmatch_ra(
X_T = X_T_lin,
Y_T = Y_T,
X_C = X_C_lin,
Y_C = Y_C,
match_idx = tmp_greedy_knn$matched_Zsum - nT
)$att_ra - sim$true_ATT
# nonlinear RA on expanded covariates
Zsum_greedy_knn_debias_nl[b] <- estimate_att_postmatch_ra(
X_T = X_T_eval,
Y_T = Y_T,
X_C = X_C_eval,
Y_C = Y_C,
match_idx = tmp_greedy_knn$matched_Zsum - nT
)$att_ra - sim$true_ATT
Zsum_greedy_knn_oracle[b,] <- compute_oracle_diagnostics(
mu0_T = sim$mu0_T,
mu0_C = sim$mu0_C,
Y_T = sim$Y_T,
Y_C = sim$Y_C,
control_component = sim$control_component,
match_idx = tmp_greedy_knn$matched_Zsum - nT,
tau_T = sim$tau_T,
tau_C = sim$tau_C,
Y0_C = sim$Y0_C,
Y1_C = sim$Y1_C,
Y0_T = sim$Y0_T,
true_ATC = sim$true_ATC
)
### ground truth
good_controls = (nT+1):(2*nT)
res_truth <- compute_metric_one(
matched_controls = good_controls,
X = X_eval,
distM = distM_eval,
treat_index = treat_index,
pscore_est = pscore_est,
k = k_eval,
A_method = "knn",
is_overlap = is_overlap
)
nl_res_truth <- calc_nonlinear_eval(
X_raw = X,
X_eval = X_eval,
treat_index = treat_index,
control_index = good_controls,
n_lin = ncol(X),
subset_idx = subset_idx
)
asd_truth[b, ] <- res_truth$asd
distance_truth[b, ] <- res_truth$distance
graph_truth[b, ] <- res_truth$graph
nl_truth[b, ] <- nl_res_truth
bias_truth[b] <- estimate_att_from_matches(Y_T, Y_C, match_idx = good_controls - nT) - sim$true_ATT
# linear RA on original covariates
debias_lin_truth[b] <- estimate_att_postmatch_ra(
X_T = X_T_lin,
Y_T = Y_T,
X_C = X_C_lin,
Y_C = Y_C,
match_idx = good_controls - nT
)$att_ra - sim$true_ATT
oracle_truth[b,] <- compute_oracle_diagnostics(
mu0_T = sim$mu0_T,
mu0_C = sim$mu0_C,
Y_T = sim$Y_T,
Y_C = sim$Y_C,
control_component = sim$control_component,
match_idx = good_controls - nT,
tau_T = sim$tau_T,
tau_C = sim$tau_C,
Y0_C = sim$Y0_C,
Y1_C = sim$Y1_C,
Y0_T = sim$Y0_T,
true_ATC = sim$true_ATC
)
}
