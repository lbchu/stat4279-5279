match_idx = tmp_greedy_knn$matched_Zsum - nT,
tau_T = sim$tau_T,
tau_C = sim$tau_C,
Y0_C = sim$Y0_C,
Y1_C = sim$Y1_C,
Y0_T = sim$Y0_T,
true_ATC = sim$true_ATC
)
### ground truth
good_controls = (nT+1):(2*nT)
res_truth <- compute_metric_one(
matched_controls = good_controls,
X = X_eval,
distM = distM_eval,
treat_index = treat_index,
pscore_est = pscore_est,
k = k_eval,
A_method = "knn",
is_overlap = is_overlap
)
nl_res_truth <- calc_nonlinear_eval(
X_raw = X,
X_eval = X_eval,
treat_index = treat_index,
control_index = good_controls,
n_lin = ncol(X),
subset_idx = subset_idx
)
asd_truth[b, ] <- res_truth$asd
distance_truth[b, ] <- res_truth$distance
graph_truth[b, ] <- res_truth$graph
nl_truth[b, ] <- nl_res_truth
bias_truth[b] <- estimate_att_from_matches(Y_T, Y_C, match_idx = good_controls - nT) - sim$true_ATT
# linear RA on original covariates
debias_lin_truth[b] <- estimate_att_postmatch_ra(
X_T = X_T_lin,
Y_T = Y_T,
X_C = X_C_lin,
Y_C = Y_C,
match_idx = good_controls - nT
)$att_ra - sim$true_ATT
oracle_truth[b,] <- compute_oracle_diagnostics(
mu0_T = sim$mu0_T,
mu0_C = sim$mu0_C,
Y_T = sim$Y_T,
Y_C = sim$Y_C,
control_component = sim$control_component,
match_idx = good_controls - nT,
tau_T = sim$tau_T,
tau_C = sim$tau_C,
Y0_C = sim$Y0_C,
Y1_C = sim$Y1_C,
Y0_T = sim$Y0_T,
true_ATC = sim$true_ATC
)
}
# ------------------------------------------------------------------
# Summaries
# ------------------------------------------------------------------
mean_results_asd_df <- summarize_metric_store(asd_initial)
mean_results_asd_df <- rbind(mean_results_asd_df,
Zsum_greedy_knn_asd = colMeans(Zsum_greedy_knn_asd, na.rm = TRUE),
truth_asd = colMeans(asd_truth,na.rm=TRUE))
mean_results_distance_df <- summarize_metric_store(distance_initial)
mean_results_distance_df <- rbind(mean_results_distance_df,
Zsum_greedy_knn_distance = colMeans(Zsum_greedy_knn_distance, na.rm = TRUE),
truth_distance = colMeans(distance_truth,na.rm=TRUE))
mean_results_graph_df <- summarize_metric_store(graph_initial)
mean_results_graph_df <- rbind(mean_results_graph_df,
Zsum_greedy_knn_graph = colMeans(Zsum_greedy_knn_graph, na.rm = TRUE),
truth_graph = colMeans(graph_truth,na.rm=TRUE))
mean_results_nl_df <- summarize_metric_store(nl_initial)
mean_results_nl_df <- rbind(mean_results_nl_df,
Zsum_greedy_knn_nl = colMeans(Zsum_greedy_knn_nl, na.rm = TRUE),
truth_nl = colMeans(nl_truth,na.rm=TRUE))
mean_results_oracle_df <- summarize_metric_store(oracle_initial)
mean_results_oracle_df <- rbind(mean_results_oracle_df,
Zsum_greedy_knn_oracle = colMeans(Zsum_greedy_knn_oracle, na.rm = TRUE),
truth_oracle = colMeans(oracle_truth,na.rm=TRUE))
mean_results_bias_df <- summarize_error_store(bias_initial)
mean_results_debias_lin_df <- summarize_error_store(bias_RA_initial)
colnames(mean_results_debias_lin_df) <- c("debias_lin", "mse_debias_lin","var_debias_lin")
mean_results_bias_df <- cbind(mean_results_bias_df, mean_results_debias_lin_df)
mean_results_bias_df <- rbind(
mean_results_bias_df,
Zsum_greedy_knn = c(
bias = mean(abs(Zsum_greedy_knn_bias), na.rm = TRUE),
mse = mean(Zsum_greedy_knn_bias^2, na.rm = TRUE),
variance = var(Zsum_greedy_knn_bias, na.rm = TRUE),
debias_lin = mean(abs(Zsum_greedy_knn_debias_lin), na.rm = TRUE),
mse_debias_lin = mean(Zsum_greedy_knn_debias_lin^2, na.rm = TRUE),
var_debias_lin = var(Zsum_greedy_knn_debias_lin, na.rm = TRUE)
),
truth = c(
bias = mean(abs(bias_truth), na.rm = TRUE),
mse = mean(bias_truth^2, na.rm = TRUE),
variance = var(bias_truth, na.rm = TRUE),
debias_lin = mean(abs(debias_lin_truth), na.rm = TRUE),
mse_debias_lin = mean(debias_lin_truth^2, na.rm = TRUE),
var_debias_lin = var(debias_lin_truth, na.rm = TRUE)
)
)
mytable <- data.frame(
mean_results_asd_df,
